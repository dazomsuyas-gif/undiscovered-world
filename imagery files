<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gallery - Undiscovered World</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.4/css/lightbox.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" />
    <style>
        .gallery-hero {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 60px 30px;
            text-align: center;
        }
        .gallery-filters {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin: 40px 0;
            flex-wrap: wrap;
        }
        .filter-btn {
            padding: 10px 20px;
            border: 2px solid #e74c3c;
            background: white;
            color: #e74c3c;
            border-radius: 25px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
        }
        .filter-btn.active {
            background: #e74c3c;
            color: white;
        }
        .gallery-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 25px;
            padding: 40px 30px;
            max-width: 1400px;
            margin: 0 auto;
        }
        .gallery-item {
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            transition: all 0.3s;
        }
        .gallery-item:hover {
            transform: translateY(-10px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.2);
        }
        .gallery-item img {
            width: 100%;
            height: 250px;
            object-fit: cover;
        }
        @media (max-width: 768px) {
            .gallery-container {
                grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            }
        }
    </style>
</head>
<body>
    <header class="header">
        <div class="container">
            <h1 class="logo">🌍 Undiscovered World</h1>
            <nav>
                <ul class="nav-links">
                    <li><a href="index.html">Home</a></li>
                    <li><a href="gallery.html">Gallery</a></li>
                    <li><a href="blog.html">Blog</a></li>
                    <li><a href="about.html">About</a></li>
                    <li><a href="contact.html">Contact</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <section class="gallery-hero">
        <div class="container">
            <h1>📸 Image Gallery</h1>
            <p>Explore African & worldwide destinations, culture, and experiences</p>
        </div>
    </section>

    <div class="container" style="text-align: center;">
        <div class="gallery-filters">
            <button class="filter-btn active" onclick="filterGallery(event, 'all')">All Images</button>
            <button class="filter-btn" onclick="filterGallery(event, 'africa')">🌍 Africa</button>
            <button class="filter-btn" onclick="filterGallery(event, 'culture')">🎭 Culture</button>
            <button class="filter-btn" onclick="filterGallery(event, 'food')">🍽️ Food</button>
            <button class="filter-btn" onclick="filterGallery(event, 'nature')">🌿 Nature</button>
            <button class="filter-btn" onclick="filterGallery(event, 'people')">👥 People</button>
        </div>
    </div>

    <div class="gallery-container" id="galleryContainer"></div>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2026 Undiscovered World. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.4/js/lightbox.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
    <script>
        AOS.init({ duration: 800, once: true });

        const galleryData = [
            { title: "Mount Kilimanjaro", desc: "Africa's highest peak", img: "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=600&h=400&fit=crop", thumb: "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=300&h=250&fit=crop", cat: "africa" },
            { title: "Traditional Market", desc: "Local culture", img: "https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?w=600&h=400&fit=crop", thumb: "https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?w=300&h=250&fit=crop", cat: "culture" },
            { title: "African Cuisine", desc: "Traditional dishes", img: "https://images.unsplash.com/photo-1495521821757-a1efb6729352?w=600&h=400&fit=crop", thumb: "https://images.unsplash.com/photo-1495521821757-a1efb6729352?w=300&h=250&fit=crop", cat: "food" },
            { title: "Wildlife", desc: "Safari experience", img: "https://images.unsplash.com/photo-1516426122078-c23e76319801?w=600&h=400&fit=crop", thumb: "https://images.unsplash.com/photo-1516426122078-c23e76319801?w=300&h=250&fit=crop", cat: "nature" },
            { title: "Community", desc: "People connections", img: "https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=600&h=400&fit=crop", thumb: "https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=300&h=250&fit=crop", cat: "people" },
            { title: "Beach", desc: "Tropical paradise", img: "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=600&h=400&fit=crop", thumb: "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=300&h=250&fit=crop", cat: "africa" }
        ];

        function renderGallery(items) {
            const container = document.getElementById('galleryContainer');
            container.innerHTML = items.map((item, i) => `
                <div class="gallery-item" data-aos="fade-up" data-aos-delay="${i*50}">
                    <a href="${item.img}" data-lightbox="gallery" data-title="${item.title}">
                        <img src="${item.thumb}" alt="${item.title}">
                    </a>
                </div>
            `).join('');
            AOS.refresh();
        }

        function filterGallery(e, cat) {
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            e.target.classList.add('active');
            const filtered = cat === 'all' ? galleryData : galleryData.filter(item => item.cat === cat);
            renderGallery(filtered);
        }

        renderGallery(galleryData);
    </script>
</body>
</html>
